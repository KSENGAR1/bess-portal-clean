# Maintenance Mode Configuration
# Set this to 'true' to enable maintenance mode (shows maintenance page to all users)
# Leave as 'false' or omit to run the application normally
VITE_MAINTENANCE_MODE=false

# Example: To enable maintenance mode in Vercel:
# 1. Go to Vercel Dashboard → Your Project → Settings → Environment Variables
# 2. Add a new variable: VITE_MAINTENANCE_MODE with value: true
# 3. Redeploy (or just push to trigger auto-deploy)
# 4. Your site will show the maintenance page
# 5. To go back online, set the variable to false
